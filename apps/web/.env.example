NEXT_PUBLIC_API_URL=http://localhost:8000

# Meta / WhatsApp Embedded Signup
# Obtain from Meta Developers → Your App → Settings → Basic
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
NEXT_PUBLIC_META_GRAPH_API_VERSION=v25.0

# Set to "true" locally to enable verbose [WA-Signup] debug logs in the browser console.
# Never enable in production — errors always go to Sentry regardless of this flag.
NEXT_PUBLIC_DEBUG_META_SIGNUP=false
