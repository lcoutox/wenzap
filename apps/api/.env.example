DATABASE_URL=postgresql://nexbrain:nexbrain@localhost:5434/nexbrain
DATABASE_TEST_URL=postgresql://nexbrain:nexbrain@localhost:5433/nexbrain_test

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# Clerk authorized party: the client_id / frontend origin registered in Clerk.
# Tokens whose `azp` claim does not match this value will be rejected.
# Leave empty to skip azp validation (development only).
CLERK_EXPECTED_AZP=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
