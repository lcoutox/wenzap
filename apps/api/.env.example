DATABASE_URL=postgresql://nexbrain:nexbrain@localhost:5434/nexbrain
DATABASE_TEST_URL=postgresql://nexbrain:nexbrain@localhost:5433/nexbrain_test

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# First-party auth
AUTH_COOKIE_SECURE=false
# Set to ".wenzap.com.br" in production when frontend and API are on different subdomains
AUTH_COOKIE_DOMAIN=

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings (mock by default; set to openai for production)
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=

# Channel credential encryption
# Required for encrypted channel credentials (db: token refs).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# WhatsApp Embedded Signup (Meta App credentials)
# META_APP_SECRET must NEVER be exposed to the frontend.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v25.0

# Evolution API (bridge WhatsApp provider — unofficial, used until Meta approves
# the app for multi-tenant self-serve).
#
# EVOLUTION_API_BASE_URL / EVOLUTION_MASTER_API_KEY: global secrets used ONLY by
# this backend to provision/manage instances (create/delete). The master key is
# the AUTHENTICATION_API_KEY configured on the Evolution server itself — NOT the
# same as any individual instance's own token.
EVOLUTION_API_BASE_URL=https://nexevolution.up.railway.app
EVOLUTION_MASTER_API_KEY=
# Public base URL of this API — used to build each instance's webhook URL.
API_PUBLIC_BASE_URL=https://api.wenzap.com.br
# Manual/dev-testing var: a per-channel key referenced via config.api_key_ref =
# "env:EVOLUTION_TEST_API_KEY" for channels created outside the QR flow.
EVOLUTION_TEST_API_KEY=

# Email / Resend (Auth.6)
# Leave RESEND_API_KEY empty in dev — emails are logged instead of sent.
# Set EMAIL_SANDBOX_MODE=true to force fake email even when API key is present.
RESEND_API_KEY=
EMAIL_FROM=no-reply@seudominio.com
EMAIL_FROM_NAME=Wenzap
APP_URL=http://localhost:3000
EMAIL_SANDBOX_MODE=false

# Stripe Billing
# Get from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_...
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Use webhook endpoint: POST /webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_test_...
# Price IDs from Stripe Dashboard → Products. Only paid, self-serve plans need
# one (Scale/Enterprise are sales-assisted — see plans.is_public).
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_SCALE=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...
