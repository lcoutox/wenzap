DATABASE_URL=postgresql://nexbrain:nexbrain@localhost:5434/nexbrain
DATABASE_TEST_URL=postgresql://nexbrain:nexbrain@localhost:5433/nexbrain_test

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# First-party auth
AUTH_COOKIE_SECURE=false
# Set to ".wenzap.com.br" in production when frontend and API are on different subdomains
AUTH_COOKIE_DOMAIN=

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings (mock by default; set to openai for production)
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=

# Channel credential encryption
# Required for encrypted channel credentials (db: token refs).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# WhatsApp Embedded Signup (Meta App credentials)
# META_APP_SECRET must NEVER be exposed to the frontend.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v25.0

# Email / SendGrid (Auth.6)
# Leave SENDGRID_API_KEY empty in dev — emails are logged instead of sent.
# Set EMAIL_SANDBOX_MODE=true to force fake email even when API key is present.
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@seudominio.com
EMAIL_FROM_NAME=Wenzap
APP_URL=http://localhost:3000
EMAIL_SANDBOX_MODE=false
